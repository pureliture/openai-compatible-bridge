# 서비스 계정 키 경로 (ADC). Vertex AI User(roles/aiplatform.user) 권한 필요.
GOOGLE_APPLICATION_CREDENTIALS=/app/secrets/vertex-sa.json

# GCP 프로젝트 / 리전
VERTEX_PROJECT=your-gcp-project
VERTEX_LOCATION=us-central1

# Vertex embedding 호출 기본 task_type
VERTEX_TASK_TYPE_DEFAULT=RETRIEVAL_DOCUMENT

# 입력 토큰 초과 시 자동 절단 (false면 한도 초과 시 400)
VERTEX_AUTO_TRUNCATE=true

# bridge 보호용 키. 설정 시 client의 API-Key 칸에 동일 값 입력. 같은 private network면 비워도 됨.
BRIDGE_API_KEY=

# 토큰 만료 몇 초 전에 선갱신할지
TOKEN_REFRESH_SKEW_SECONDS=300

# Vertex 동시 호출 상한 / HTTP 타임아웃
MAX_CONCURRENCY=8
HTTP_TIMEOUT_SECONDS=60

# Ollama native API base URL. Docker에서 host Ollama를 쓰면 host.docker.internal을 사용한다.
OLLAMA_BASE_URL=http://host.docker.internal:11434

# KNOWN_MAX_INSTANCES에 없는 모델의 요청당 instance 폴백(안전값 1)
DEFAULT_MAX_INSTANCES=1

# 허용 모델 화이트리스트 추가(쉼표구분). 기본 3개 외 Vertex 임베딩 모델을 쓸 때만 추가.
# 여기 없는 model 이름은 404로 거부됨(path 주입 방지). 예: EXTRA_MODELS=text-embedding-004
EXTRA_MODELS=

# 비용 추적 / hard budget gate. 실제 예산값과 admin key는 운영 환경에서만 채운다.
COST_TRACKING_ENABLED=false
COST_LEDGER_PATH=/data/cost-ledger.db
COST_LEDGER_DIR=./data
COST_PRICING_JSON=
COST_PRICING_PATH=
COST_SHORT_WINDOW_SECONDS=
COST_SHORT_WINDOW_LIMIT_USD=
COST_DAILY_LIMIT_USD=

# 비용 admin API. BRIDGE_API_KEY와 별도 키를 사용한다.
COST_ADMIN_ENABLED=false
COST_ADMIN_API_KEY=

# Cloud Billing BigQuery reconciliation. export 설정/권한은 별도 운영 작업으로 준비한다.
COST_RECONCILIATION_ENABLED=false
COST_BILLING_BIGQUERY_PROJECT=
COST_BILLING_BIGQUERY_DATASET=
COST_BILLING_BIGQUERY_TABLE=
COST_RETENTION_REQUEST_DAYS=90
COST_RETENTION_AGGREGATE_MONTHS=13
